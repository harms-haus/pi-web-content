{
  "name": "pi-web-content",
  "version": "1.0.0",
  "description": "Web content fetching and git repository cloning extension for the pi coding agent",
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src/**/*.{ts,js,map}",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "echo 'nothing to build'",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "npx vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "npx tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^26.0.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "overrides": {
    "@mistralai/mistralai": "npm:empty-npm-package@1.0.0"
  }
}
